DOGIDO_BIND_HOST=127.0.0.1
DOGIDO_BIND_PORT=5055
DOGIDO_DEFAULT_CALL_NAME=プレイヤー
DOGIDO_AUDIO_ENABLED=true
DOGIDO_DECISION_POLICY=py_trees
DOGIDO_LLM_ENABLED=true
DOGIDO_LLM_BACKEND=mlx
DOGIDO_LLM_PROVIDER=local
DOGIDO_TTS_BACKEND=voicevox
DOGIDO_CUE_BACKEND=afplay
DOGIDO_VOICEVOX_URL=http://127.0.0.1:50021
DOGIDO_VOICEVOX_SPEAKER=21
DOGIDO_CUE_AUDIO_DIR=cue_voice
DOGIDO_MLX_MODEL_ID=mlx-community/Qwen3.6-35B-A3B-4bit-DWQ

# Chat Completions backend example: local server
# DOGIDO_LLM_BACKEND=chat_completions
# DOGIDO_LLM_PROVIDER=local
# DOGIDO_LLM_BASE_URL=http://127.0.0.1:8080/v1
# DOGIDO_LLM_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit-DWQ
# DOGIDO_LLM_API_KEY=

# Chat Completions backend example: OpenAI
# DOGIDO_LLM_BACKEND=chat_completions
# DOGIDO_LLM_PROVIDER=openai
# DOGIDO_LLM_MODEL=gpt-4.1-mini
# DOGIDO_LLM_API_KEY=

# Chat Completions backend example: OpenRouter
# DOGIDO_LLM_BACKEND=chat_completions
# DOGIDO_LLM_PROVIDER=openrouter
# DOGIDO_LLM_MODEL=openai/gpt-4.1-mini
# DOGIDO_LLM_API_KEY=
# DOGIDO_LLM_HTTP_REFERER=https://example.com
# DOGIDO_LLM_APPLICATION_NAME=Dogido

# Route-specific override example:
# chat = 雑談 / 助言、haiku = 川柳
# backend は未指定でも provider が local 以外なら API family に自動解決されます。
#
# DOGIDO_LLM_CHAT_PROVIDER=local
# DOGIDO_LLM_CHAT_BASE_URL=http://127.0.0.1:8080/v1
# DOGIDO_LLM_CHAT_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit-DWQ
#
# DOGIDO_LLM_HAIKU_PROVIDER=openai
# DOGIDO_LLM_HAIKU_MODEL=gpt-4.1
# DOGIDO_LLM_HAIKU_API_KEY=
#
# Provider examples:
# DOGIDO_LLM_CHAT_PROVIDER=claude
# DOGIDO_LLM_CHAT_MODEL=claude-sonnet-4-20250514
# DOGIDO_LLM_CHAT_API_KEY=
#
# DOGIDO_LLM_CHAT_PROVIDER=grok
# DOGIDO_LLM_CHAT_MODEL=grok-4-fast-reasoning
# DOGIDO_LLM_CHAT_API_KEY=
#
# DOGIDO_LLM_CHAT_PROVIDER=gemini
# DOGIDO_LLM_CHAT_MODEL=gemini-2.5-flash
# DOGIDO_LLM_CHAT_API_KEY=
#
# DOGIDO_LLM_HAIKU_PROVIDER=openrouter
# DOGIDO_LLM_HAIKU_MODEL=anthropic/claude-sonnet-4
# DOGIDO_LLM_HAIKU_API_KEY=
# DOGIDO_LLM_HAIKU_HTTP_REFERER=https://example.com
# DOGIDO_LLM_HAIKU_APPLICATION_NAME=Dogido
